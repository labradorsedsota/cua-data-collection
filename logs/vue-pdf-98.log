import { findMatches, highlightMatches, resetDivs } from "/src/components/utils/highlight.ts";

props: {
  page: { type: Object, required: false },
  viewport: { type: Object, required: false },
  highlightText: { type: String, required: false },    // ← String type!
  highlightOptions: { type: Object, required: false }
}

async function findAndHighlight(reset = false) {
  const page = props.page;
  const textContent = await page?.getTextContent();
  if (!textContent) return;
  if (reset) resetDivs(textContent, textDivs);
  if (props.highlightText) {
    const matches = findMatches(props.highlightText, textContent, getHighlightOptionsWithDefaults());
    highlightMatches(matches, textContent, textDivs);
    emit("highlight", {
      matches,
      textContent,
      textDivs,
      page: page?.pageNumber || 1
    });
  }
}
```

